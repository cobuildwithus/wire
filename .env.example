# Required for `pnpm generate` (wagmi -> Basescan)
BASESCAN_API_KEY=your_basescan_api_key_here

# Optional protocol contract addresses for ABI generation.
# If unset or invalid, wagmi skips fetch and wire falls back to static ABI event signatures.
CORE_GOAL_FLOW_ADDRESS=0x0000000000000000000000000000000000000000
CORE_GOAL_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
CORE_BUDGET_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
CORE_PREMIUM_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
CORE_GOAL_STAKE_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
CORE_BUDGET_STAKE_LEDGER_ADDRESS=0x0000000000000000000000000000000000000000
CORE_BUDGET_TCR_ADDRESS=0x0000000000000000000000000000000000000000
CORE_BUDGET_TCR_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
CORE_GOAL_FLOW_ALLOCATION_LEDGER_PIPELINE_ADDRESS=0x0000000000000000000000000000000000000000
CORE_GOAL_REVNET_SPLIT_HOOK_ADDRESS=0x0000000000000000000000000000000000000000
